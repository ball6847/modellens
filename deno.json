{
  "tasks": {
    "dev": "deno task dev:api & deno task dev:web",
    "dev:api": "deno run --allow-net --allow-read --allow-write --allow-env server/main.ts",
    "dev:web": "cd web && npm run dev",
    "build": "deno compile --allow-net --allow-read --allow-write --allow-env --output modellens server/main.ts",
    "serve": "./modellens"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4"
  }
}
